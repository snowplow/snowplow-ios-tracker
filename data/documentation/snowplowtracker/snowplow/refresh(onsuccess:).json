{"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Reconfigure, create or delete the trackers based on the configuration downloaded remotely."}],"variants":[{"paths":["\/documentation\/snowplowtracker\/snowplow\/refresh(onsuccess:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow\/refresh(onSuccess:)"},"hierarchy":{"paths":[["doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker","doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow"]]},"metadata":{"roleHeading":"Type Method","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"refresh","kind":"identifier"},{"text":"(","kind":"text"},{"text":"onSuccess","kind":"externalParam"},{"text":": ([","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"]?, ","kind":"text"},{"text":"ConfigurationState","kind":"typeIdentifier","preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")","kind":"text"}],"title":"refresh(onSuccess:)","modules":[{"name":"SnowplowTracker"}],"symbolKind":"method","externalID":"c:@M@SnowplowTracker@objc(cs)SPSnowplow(cm)refreshOnSuccess:"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@objc"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refresh"},{"kind":"text","text":"("},{"kind":"externalParam","text":"onSuccess"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" (["},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"]?, "},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState","text":"ConfigurationState","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationState"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"onSuccess","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The callback called when a configuration (cached or downloaded) is set It passes the list of the namespaces associated"},{"type":"text","text":" "},{"type":"text","text":"to the created trackers."}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The trackers configuration is automatically download from the endpoint indicated in the "},{"code":"RemoteConfiguration","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"previously used to setup the trackers."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The method is asynchronous and you can receive the list of the created trackers in the callbacks once the trackers are created."},{"type":"text","text":" "},{"type":"text","text":"The downloaded configuration updates the cached one only if the configuration version is greater than the cached one."},{"type":"text","text":" "},{"type":"text","text":"Otherwise the cached one is kept and the callback is not called."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"IMPORTANT: The EventStore will persist all the events that have been tracked but not yet sent."},{"type":"text","text":" "},{"type":"text","text":"Those events are attached to the namespace."},{"type":"text","text":" "},{"type":"text","text":"If the tracker is removed or the app relaunched with a different namespace, those events can’t"},{"type":"text","text":" "},{"type":"text","text":"be sent to the collector and they remain in a zombie state inside the EventStore."},{"type":"text","text":" "},{"type":"text","text":"To remove all the zombie events you can call an internal method "},{"code":"removeUnsentEventsExceptForNamespaces","type":"codeVoice"},{"type":"text","text":" on "},{"code":"SPSQLEventStore","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"which will delete all the EventStores instanced with namespaces not listed in the passed list."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://SnowplowTracker/documentation/SnowplowTracker/Snowplow":{"abstract":[{"text":"Entry point to instance a new Snowplow tracker.","type":"text"}],"role":"symbol","type":"topic","navigatorTitle":[{"text":"Snowplow","kind":"identifier"}],"url":"\/documentation\/snowplowtracker\/snowplow","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Snowplow","kind":"identifier"}],"title":"Snowplow","kind":"symbol"},"doc://SnowplowTracker/documentation/SnowplowTracker":{"type":"topic","title":"SnowplowTracker","abstract":[],"role":"collection","kind":"symbol","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker","url":"\/documentation\/snowplowtracker"},"doc://SnowplowTracker/documentation/SnowplowTracker/Snowplow/refresh(onSuccess:)":{"type":"topic","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow\/refresh(onSuccess:)","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"refresh","kind":"identifier"},{"text":"(","kind":"text"},{"text":"onSuccess","kind":"externalParam"},{"text":": ([","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"]?, ","kind":"text"},{"preciseIdentifier":"c:@M@SnowplowTracker@E@SPCo