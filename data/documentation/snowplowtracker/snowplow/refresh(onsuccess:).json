{"abstract":[{"text":"Reconfigure, create or delete the trackers based on the configuration downloaded remotely.","type":"text"}],"sections":[],"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refresh"},{"kind":"text","text":"("},{"kind":"externalParam","text":"onSuccess"},{"kind":"text","text":": (["},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"]?, "},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState","text":"ConfigurationState"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")"}],"roleHeading":"Type Method","modules":[{"name":"SnowplowTracker"}],"role":"symbol","externalID":"c:@M@SnowplowTracker@objc(cs)SPSnowplow(cm)refreshOnSuccess:","symbolKind":"method","title":"refresh(onSuccess:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@objc"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refresh"},{"kind":"text","text":"("},{"kind":"externalParam","text":"onSuccess"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" (["},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"]?, "},{"kind":"typeIdentifier","preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationState","text":"ConfigurationState"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":")"}]}],"kind":"declarations"},{"parameters":[{"name":"onSuccess","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The callback called when a configuration (cached or downloaded) is set It passes the list of the namespaces associated"},{"type":"text","text":" "},{"type":"text","text":"to the created trackers."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The trackers configuration is automatically download from the endpoint indicated in the "},{"code":"RemoteConfiguration","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"previously used to setup the trackers."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The method is asynchronous and you can receive the list of the created trackers in the callbacks once the trackers are created."},{"type":"text","text":" "},{"type":"text","text":"The downloaded configuration updates the cached one only if the configuration version is greater than the cached one."},{"type":"text","text":" "},{"type":"text","text":"Otherwise the cached one is kept and the callback is not called."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"IMPORTANT: The EventStore will persist all the events that have been tracked but not yet sent."},{"type":"text","text":" "},{"type":"text","text":"Those events are attached to the namespace."},{"type":"text","text":" "},{"type":"text","text":"If the tracker is removed or the app relaunched with a different namespace, those events can’t"},{"type":"text","text":" "},{"type":"text","text":"be sent to the collector and they remain in a zombie state inside the EventStore."},{"type":"text","text":" "},{"type":"text","text":"To remove all the zombie events you can call an internal method "},{"type":"codeVoice","code":"removeUnsentEventsExceptForNamespaces"},{"type":"text","text":" on "},{"type":"codeVoice","code":"SPSQLEventStore"},{"type":"text","text":" "},{"type":"text","text":"which will delete all the EventStores instanced with namespaces not listed in the passed list."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow\/refresh(onSuccess:)"},"variants":[{"paths":["\/documentation\/snowplowtracker\/snowplow\/refresh(onsuccess:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker","doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow"]]},"kind":"symbol","references":{"doc://SnowplowTracker/documentation/SnowplowTracker/ConfigurationState":{"abstract":[{"text":"State of retrieved remote configuration that states where the configuration was retrieved from.","type":"text"}],"title":"ConfigurationState","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationState","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ConfigurationState","kind":"identifier"}],"navigatorTitle":[{"text":"ConfigurationState","kind":"identifier"}],"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/snowplowtracker\/configurationstate"},"doc://SnowplowTracker/documentation/SnowplowTracker/Snowplow":{"abstract":[{"type":"text","text":"Entry point to instance a new Snowplow tracker."}],"identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Snowplow"}],"kind":"symbol","url":"\/documentation\/snowplowtracker\/snowplow","title":"Snowplow","navigatorTitle":[{"kind":"identifier","text":"Snowplow"}]},"doc://SnowplowTracker/documentation/SnowplowTracker/Snowplow/refresh(onSuccess:)":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"refresh","kind":"identifi