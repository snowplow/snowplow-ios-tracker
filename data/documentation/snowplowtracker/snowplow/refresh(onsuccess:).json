"To remove all the zombie events you can call an internal method ","type":"text"},{"code":"removeUnsentEventsExceptForNamespaces","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"SPSQLEventStore","type":"codeVoice"},{"text":" ","type":"text"},{"text":"which will delete all the EventStores instanced with namespaces not listed in the passed list.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow\/refresh(onSuccess:)"},"references":{"doc://SnowplowTracker/documentation/SnowplowTracker/ConfigurationState":{"kind":"symbol","title":"ConfigurationState","url":"\/documentation\/snowplowtracker\/configurationstate","navigatorTitle":[{"kind":"identifier","text":"ConfigurationState"}],"abstract":[{"type":"text","text":"State of retrieved remote configuration that states where the configuration was retrieved from."}],"role":"symbol","type":"topic","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationState","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConfigurationState"}]},"doc://SnowplowTracker/documentation/SnowplowTracker":{"kind":"symbol","title":"SnowplowTracker","abstract":[],"role":"collection","type":"topic","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker","url":"\/documentation\/snowplowtracker"},"doc://SnowplowTracker/documentation/SnowplowTracker/Snowplow/refresh(onSuccess:)":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refresh"},{"kind":"text","text":"("},{"kind":"externalParam","text":"onSuccess"},{"kind":"text","text":": (["},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"]?, "},{"kind":"typeIdentifier","text":"ConfigurationState","preci