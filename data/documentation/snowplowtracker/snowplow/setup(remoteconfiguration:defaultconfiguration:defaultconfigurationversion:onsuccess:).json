{"identifier":{"url":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow\/setup(remoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker","doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow"]]},"kind":"symbol","abstract":[{"text":"Setup a single or a set of tracker instances which will be used inside the app to track events.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/snowplowtracker\/snowplow\/setup(remoteconfiguration:defaultconfiguration:defaultconfigurationversion:onsuccess:)"]}],"sections":[],"metadata":{"externalID":"c:@M@SnowplowTracker@objc(cs)SPSnowplow(cm)setupWithRemoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:","roleHeading":"Type Method","modules":[{"name":"SnowplowTracker"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setup","kind":"identifier"},{"text":"(","kind":"text"},{"text":"remoteConfiguration","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPRemoteConfiguration","text":"RemoteConfiguration","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"defaultConfiguration","kind":"externalParam"},{"text":": [","kind":"text"},{"preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPConfigurationBundle","text":"ConfigurationBundle","kind":"typeIdentifier"},{"text":"]?, ","kind":"text"},{"text":"defaultConfigurationVersion","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"onSuccess","kind":"externalParam"},{"text":": ([","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"]?, ","kind":"text"},{"preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState","text":"ConfigurationState","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"setup(remoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:)","symbolKind":"method","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setup","kind":"identifier"},{"text":"(","kind":"text"},{"text":"remoteConfiguration","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"RemoteConfiguration","kind":"typeIdentifier","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/RemoteConfiguration","preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPRemoteConfiguration"},{"text":", ","kind":"text"},{"text":"defaultConfiguration","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"defaultBundles","kind":"internalParam"},{"text":": [","kind":"text"},{"text":"ConfigurationBundle","kind":"typeIdentifier","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationBundle","preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPConfigurationBundle"},{"text":"]?, ","kind":"text"},{"text":"defaultConfigurationVersion","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"defaultBundleVersion","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":" = NSInteger.min, ","kind":"text"},{"text":"onSuccess","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" ([","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"]?, ","kind":"text"},{"text":"ConfigurationState","kind":"typeIdentifier","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationState","preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")","kind":"text"}],"platforms":["macOS"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The remote configuration used to indicate where to download the configuration from.","type":"text"}]}],"name":"remoteConfiguration"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The default configuration passed by default in case there isn’t a cached version and it’s able to download a new one.","type":"text"}]}],"name":"defaultBundles"},{"content":[{"inlineContent":[{"type":"text","text":"Version of the default configuration that will be used to compare with the fetched remote config to decide whether to replace it."}],"type":"paragraph"}],"name":"defaultBundleVersion"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The callback called when a configuration (cached or downloaded) is set.","type":"text"},{"text":" ","type":"text"},{"text":"It passes two arguments: list of the namespaces associated to the created trackers","type":"text"},{"text":" ","type":"text"},{"text":"and the state of the configuration – whether it was retrieved from cache or fetched over the network.","type":"text"}]}],"name":"onSuccess"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The app can run multiple tracker instances which will be identified by string "},{"type":"codeVoice","code":"namespaces"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The trackers configuration is automatically download from the endpoint indicated in the "},{"type":"codeVoice","code":"RemoteConfiguration"},{"type":"text","text":" "},{"type":"text","text":"passed as argument. For more details see "},{"type":"codeVoice","code":"RemoteConfiguration"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The method is asynchronous and you can receive the list of the created trackers in the callbacks once the trackers are created.","type":"text"},{"text":" ","type":"text"},{"text":"The callback can be called multiple times in case a cached configuration is ready and later a fetched configuration is available.","type":"text"},{"text":" ","type":"text"},{"text":"You can also pass as argument a default configuration in case there isn’t a cached configuration and it’s not able to download","type":"text"},{"text":" ","type":"text"},{"text":"a new one. The downloaded configuration updates the cached one only if the configuration version is greater than the cached one.","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise the cached one is kept and the callback is not called.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"IMPORTANT: The EventStore will persist all the events that have been tracked but not yet sent."},{"type":"text","text":" "},{"type":"text","text":"Those events are attached to the namespace."},{"type":"text","text":" "},{"type":"text","text":"If the tracker is removed or the app relaunched with a different namespace, those events can’t"},{"type":"text","text":" "},{"type":"text","text":"be sent to the collector and they remain in a zombie state inside the EventStore."},{"type":"text","text":" "},{"type":"text","text":"To remove all the zombie events you can call an internal method "},{"type":"codeVoice","code":"removeUnsentEventsExceptForNamespaces"},{"type":"text","text":" on "},{"type":"codeVoice","code":"SPSQLEventStore"},{"type":"text","text":" "},{"type":"text","text":"which will delete all the EventStores instanced with namespaces not listed in the passed list."}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://SnowplowTracker/documentation/SnowplowTracker/RemoteConfiguration":{"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"RemoteConfiguration"}],"title":"RemoteConfiguration","kind":"symbol","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/RemoteConfiguration","navigatorTitle":[{"kind":"identifier","text":"RemoteConfiguration"}],"url":"\/documentation\/snowplowtracker\/remoteconfiguration","abstract":[{"text":"Represents the configuration for fetching configurations from a remote source.","type":"text"},{"text":" ","type":"text"},{"text":"For details on the correct format of a remote configuration see the official documentation.","type":"text"}],"type":"topic"},"doc://SnowplowTracker/documentation/SnowplowTracker/Snowplow":{"abstract":[{"text":"Entry point to instance a new Snowplow tracker.","type":"text"}],"role":"symbol","type":"topic","navigatorTitle":[{"text":"Snowplow","kind":"identifier"}],"url":"\/documentation\/snowplowtracker\/snowplow","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Snowplow","kind":"identifier"}],"title":"Snowplow","kind":"symbol"},"doc://SnowplowTracker/documentation/SnowplowTracker/Snowplow/setup(remoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:)":{"url":"\/documentation\/snowplowtracker\/snowplow\/setup(remoteconfiguration:defaultconfiguration:defaultconfigurationversion:onsuccess:)","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow\/setup(remoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:)","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setup","kind":"identifier"},{"text":"(","kind":"text"},{"tex