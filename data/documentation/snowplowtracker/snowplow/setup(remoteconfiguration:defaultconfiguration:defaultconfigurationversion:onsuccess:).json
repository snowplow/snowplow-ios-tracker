eIdentifier","preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")","kind":"text"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setup","kind":"identifier"},{"text":"(","kind":"text"},{"text":"remoteConfiguration","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"RemoteConfiguration","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/RemoteConfiguration","preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPRemoteConfiguration","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"defaultConfiguration"},{"kind":"text","text":" "},{"kind":"internalParam","text":"defaultBundles"},{"kind":"text","text":": ["},{"preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPConfigurationBundle","kind":"typeIdentifier","text":"ConfigurationBundle","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationBundle"},{"kind":"text","text":"]?, "},{"kind":"externalParam","text":"defaultConfigurationVersion"},{"kind":"text","text":" "},{"kind":"internalParam","text":"defaultBundleVersion"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":" = NSInteger.min, "},{"kind":"externalParam","text":"onSuccess"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" (["},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":"]?, "},{"preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState","kind":"typeIdentifier","text":"ConfigurationState","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationState"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"remoteConfiguration","content":[{"type":"paragraph","inlineContent":[{"text":"The remote configuration used to indicate where to download the configuration from.","type":"text"}]}]},{"name":"defaultBundles","content":[{"inlineContent":[{"type":"text","text":"The default configuration passed by default in case there isn’t a cached version and it’s able to download a new one."}],"type":"paragraph"}]},{"name":"defaultBundleVersion","content":[{"inlineContent":[{"text":"Version of the default configuration that will be used to compare with the fetched remote config to decide whether to replace it.","type":"text"}],"type":"paragraph"}]},{"name":"onSuccess","content":[{"inlineContent":[{"text":"The callback called when a configuration (cached or downloaded) is set.","type":"text"},{"text":" ","type":"text"},{"text":"It passes two arguments: list of the namespaces associated to the created trackers","type":"text"},{"text":" ","type":"text"},{"text":"and the state of the configuration – whether it was retrieved from cache or fetched over the network.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app can run multiple tracker instances which will be identified by string "},{"code":"namespaces","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The trackers configuration is automatically download from the endpoint indicated in the "},{"code":"RemoteConfiguration","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"passed as argument. For more details see "},{"code":"RemoteConfiguration","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The method is asynchronous and you can receive the list of the created trackers in the callbacks once the trackers are created."},{"type":"text","text":" "},{"type":"text","text":"The callback can be called multiple times in case a cached configuration is ready and later a fetched configuration is available."},{"type":"text","text":" "},{"type":"text","text":"You can also pass as argument a default configuration in case there isn’t a cached configuration and it’s not able to download"},{"type":"text","text":" "},{"type":"text","text":"a new one. The downloaded configuration updates the cached one only if the configuration version is greater than the cached one."},{"type":"text","text":" "},{"type":"text","text":"Otherwise the cached one is kept and the callback is not called."}]},{"type":"paragraph","inlineContent":[{"text":"IMPORTANT: The EventStore will persist all the events that have been tracked but not yet sent.","type":"text"},{"text":" ","type":"text"},{"text":"Those events are attached to the namespace.","type":"text"},{"text":" ","type":"text"},{"text":"If the tracker is removed or the app relaunched with a different namespace, those events can’t","type":"text"},{"text":" ","type":"text"},{"text":"be sent to the collector and they remain in a zombie state inside the EventStore.","type":"text"},{"text":" ","type":"text"},{"text":"To remove all the zombie events you can call an internal method ","type":"text"},{"code":"removeUnsentEventsExceptForNamespaces","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"SPSQLEventStore","type":"codeVoice"},{"text":" ","type":"text"},{"text":"which will delete all the EventStores instanced with namespaces not listed in the passed list.","type":"text"}]}]}],"identifier":{"url":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow\/setup(remoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:)","interfaceLanguage":"swi