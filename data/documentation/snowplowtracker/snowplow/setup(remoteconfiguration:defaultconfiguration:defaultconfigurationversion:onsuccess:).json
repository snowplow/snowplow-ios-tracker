{"identifier":{"url":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow\/setup(remoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:)","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"metadata":{"symbolKind":"method","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setup"},{"kind":"text","text":"("},{"kind":"externalParam","text":"remoteConfiguration"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPRemoteConfiguration","kind":"typeIdentifier","text":"RemoteConfiguration"},{"kind":"text","text":", "},{"kind":"externalParam","text":"defaultConfiguration"},{"kind":"text","text":": ["},{"preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPConfigurationBundle","kind":"typeIdentifier","text":"ConfigurationBundle"},{"kind":"text","text":"]?, "},{"kind":"externalParam","text":"defaultConfigurationVersion"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"onSuccess"},{"kind":"text","text":": (["},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":"]?, "},{"preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState","kind":"typeIdentifier","text":"ConfigurationState"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":")"}],"externalID":"c:@M@SnowplowTracker@objc(cs)SPSnowplow(cm)setupWithRemoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:","modules":[{"name":"SnowplowTracker"}],"title":"setup(remoteConfiguration:defaultConfiguration:defaultConfigurationVersion:onSuccess:)","roleHeading":"Type Method","role":"symbol"},"variants":[{"paths":["\/documentation\/snowplowtracker\/snowplow\/setup(remoteconfiguration:defaultconfiguration:defaultconfigurationversion:onsuccess:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@objc"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setup"},{"kind":"text","text":"("},{"kind":"externalParam","text":"remoteConfiguration"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPRemoteConfiguration","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/RemoteConfiguration","kind":"typeIdentifier","text":"RemoteConfiguration"},{"text":", ","kind":"text"},{"text":"defaultConfiguration","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"defaultBundles","kind":"internalParam"},{"text":": [","kind":"text"},{"text":"ConfigurationBundle","kind":"typeIdentifier","preciseIdentifier":"c:@M@SnowplowTracker@objc(cs)SPConfigurationBundle","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationBundle"},{"text":"]?, ","kind":"text"},{"text":"defaultConfigurationVersion","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"defaultBundleVersion","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":" = NSInteger.min, ","kind":"text"},{"text":"onSuccess","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" ([","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"]?, ","kind":"text"},{"text":"ConfigurationState","kind":"typeIdentifier","preciseIdentifier":"c:@M@SnowplowTracker@E@SPConfigurationState","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationState"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":")","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The remote configuration used to indicate where to download the configuration from.","type":"text"}]}],"name":"remoteConfiguration"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The default configuration passed by default in case there isn’t a cached version and it’s able to download a new one.","type":"text"}]}],"name":"defaultBundles"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Version of the default configuration that will be used to compare with the fetched remote config to decide whether to replace it."}]}],"name":"defaultBundleVersion"},{"content":[{"inlineContent":[{"type":"text","text":"The callback called when a configuration (cached or downloaded) is set."},{"type":"text","text":" "},{"type":"text","text":"It passes two arguments: list of the namespaces associated to the created trackers"},{"type":"text","text":" "},{"type":"text","text":"and the state of the configuration – whether it was retrieved from cache or fetched over the network."}],"type":"paragraph"}],"name":"onSuccess"}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The app can run multiple tracker instances which will be identified by string "},{"type":"codeVoice","code":"namespaces"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The trackers configuration is automatically download from the endpoint indicated in the "},{"type":"codeVoice","code":"RemoteConfiguration"},{"type":"text","text":" "},{"type":"text","text":"passed as argument. For more details see "},{"type":"codeVoice","code":"RemoteConfiguration"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The method is asynchronous and you can receive the list of the created trackers in the callbacks once the trackers are created."},{"type":"text","text":" "},{"type":"text","text":"The callback can be called multiple times in case a cached configuration is ready and later a fetched configuration is available."},{"type":"text","text":" "},{"type":"text","text":"You can also pass as argument a default configuration in case there isn’t a cached configuration and it’s not able to download"},{"type":"text","text":" "},{"type":"text","text":"a new one. The downloaded configuration updates the cached one only if the configuration version is greater than the cached one."},{"type":"text","text":" "},{"type":"text","text":"Otherwise the cached one is kept and the callback is not called."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"IMPORTANT: The EventStore will persist all the events that have been tracked but not yet sent."},{"type":"text","text":" "},{"type":"text","text":"Those events are attached to the namespace."},{"type":"text","text":" "},{"type":"text","text":"If the tracker is removed or the app relaunched with a different namespace, those events can’t"},{"type":"text","text":" "},{"type":"text","text":"be sent to the collector and they remain in a zombie state inside the EventStore."},{"type":"text","text":" "},{"type":"text","text":"To remove all the zombie events you can call an internal method "},{"code":"removeUnsentEventsExceptForNamespaces","type":"codeVoice"},{"type":"text","text":" on "},{"code":"SPSQLEventStore","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"which will delete all the EventStores instanced with namespaces not listed in the passed list."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker","doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/Snowplow"]]},"abstract":[{"type":"text","text":"Setup a single or a set of tracker instances which will be used inside the app to track events."}],"references":{"doc://SnowplowTracker/documentation/SnowplowTracker/RemoteConfiguration":{"navigatorTitle":[{"kind":"identifier","text":"RemoteConfiguration"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Represents the configuration for fetching configurations from a remote source."},{"type":"text","text":" "},{"type":"text","text":"For details on the correct format of a remote configuration see the official documentation."}],"type":"topic","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/RemoteConfiguration","url":"\/documentation\/snowplowtracker\/remoteconfiguration","title":"RemoteConfiguration","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"RemoteConfiguration"}]},"doc://SnowplowTracker/documentation/SnowplowTracker/ConfigurationBundle":{"abstract":[{"type":"text","text":"This class represents the default configuration applied in place of the remote configuration."}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConfigurationBundle"}],"identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationBundle","title":"ConfigurationBundle","navigatorTitle":[{"kind":"identifier","text":"ConfigurationBundle"}],"url":"\/documentation\/snowplowtracker\/configurationbundle"},"doc://SnowplowTracker/documentation/SnowplowTracker/ConfigurationState":{"navigatorTitle":[{"text":"ConfigurationState","kind":"identifier"}],"type":"topic","title":"ConfigurationState","identifier":"doc:\/\/SnowplowTracker\/documentation\/SnowplowTracker\/ConfigurationState","abstract":[{"text":"State of retrieved remote configuration that states where the configuration was retrieved from.","type":"text"}],"url":"\/documentation\/snowplowtracker\/configurationstate","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Configurati